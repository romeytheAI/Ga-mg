body {
    font-family: sans-serif;
    background-color: #1a1a1a;
    color: #eee;
}
.game-container {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
}
.stats-panel {
    flex: 1;
    padding: 1rem;
    background-color: #2a2a2a;
}
.main-panel {
    flex: 3;
    padding: 1rem;
}
.action-buttons button {
    padding: 0.5rem 1rem;
    margin: 0.25rem;
    background-color: #4CAF50;
    color: white;
    border: none;
    cursor: pointer;
}
.action-buttons button:hover {
    background-color: #45a049;
}
