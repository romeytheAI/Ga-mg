# ====================
# DAFL Revenue Sidecar
# Environment Variables
# ====================

# AI API Keys (for content generation)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Payment Processing
STRIPE_SECRET=your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# GitHub Integration
GITHUB_PAT=your_github_personal_access_token

# Social Media APIs
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
YOUTUBE_API_KEY=your_youtube_api_key
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# Reddit API (for trend scraping)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=DAFL/1.0

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Optional: TTS Services
# GOOGLE_TTS_API_KEY=your_google_tts_key
# ELEVENLABS_API_KEY=your_elevenlabs_key
# AWS_ACCESS_KEY_ID=your_aws_key  # For Amazon Polly
# AWS_SECRET_ACCESS_KEY=your_aws_secret

# Optional: Advanced Features
# OPENAI_ORG_ID=your_openai_org_id
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_ENDPOINT=your_azure_endpoint

# Application Settings
LOG_LEVEL=INFO
CHECK_INTERVAL=3600  # Reinvestment check interval (seconds)
BUFFER_RATIO=0.20    # 20% buffer over projected costs

# Database (optional, for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/dafl
