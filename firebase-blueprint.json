{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and game state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "gameState": { "type": "string", "description": "JSON stringified GameState" }
      },
      "required": ["uid", "email", "role", "createdAt", "gameState"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and saved games"
    }
  }
}
